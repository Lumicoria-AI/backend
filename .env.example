# ===========================================================================
# Lumicoria AI — Backend Environment Variables
# ===========================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ===========================================================================

# ── REQUIRED ──────────────────────────────────────────────────────────────
# The app will refuse to start without these two variables.

# JWT signing key — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Perplexity Sonar API key (get from https://www.perplexity.ai/settings/api)
PERPLEXITY_API_KEY=

# ── ENVIRONMENT ───────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ── GOOGLE OAUTH ──────────────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=

# ── FIREBASE ──────────────────────────────────────────────────────────────
# Path to Firebase Admin SDK service-account JSON file
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# ── MONGODB ───────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=lumicoria

# ── POSTGRESQL / SQLALCHEMY (optional) ───────────────────────────────────
POSTGRES_ENABLED=false
POSTGRES_DUAL_WRITE=false
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=lumicoria
# Optional override:
# SQLALCHEMY_DATABASE_URI=postgresql://postgres:password@localhost:5432/lumicoria

# ── CASSANDRA (optional) ────────────────────────────────────────────────
CASSANDRA_ENABLED=false
CASSANDRA_DUAL_WRITE=false
CASSANDRA_HOSTS=["localhost"]
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=lumicoria
CASSANDRA_REPLICATION_FACTOR=1
CASSANDRA_USERNAME=
CASSANDRA_PASSWORD=

# ── REDIS ─────────────────────────────────────────────────────────────────
# Used for rate limiting and caching
# (nested settings under "db" prefix also work — see config.py)

# ── VECTOR STORE ──────────────────────────────────────────────────────────
# VECTOR_STORE_TYPE=weaviate|qdrant|chroma
VECTOR_STORE_TYPE=weaviate
VECTOR_STORE_URL=http://localhost:8081
VECTOR_STORE_API_KEY=
VECTOR_STORE_COLLECTION=documents
VECTOR_STORE_DIMENSION=1536
VECTOR_STORE_ENABLED=true

# ── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list or JSON array of allowed origins
BACKEND_CORS_ORIGINS=["http://localhost:8080","http://localhost:3000","http://127.0.0.1:8080","http://127.0.0.1:3000"]

# ── SMTP (optional — needed for email features) ──────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# ── INTEGRATION ENCRYPTION ───────────────────────────────────────────────
# Fernet key for encrypting third-party integration credentials.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: If you lose this key, all encrypted integration creds become unreadable.
INTEGRATION_ENCRYPTION_KEY=

# ── OPENAI (optional) ────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview

# ── SENTRY (optional — error monitoring) ──────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── CLOUD PROVIDERS (optional) ───────────────────────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── THIRD-PARTY INTEGRATIONS (optional) ──────────────────────────────────
NOTION_API_KEY=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=
