# API Settings
ENVIRONMENT=development
DEBUG=true
API_V1_STR=/api/v1
PROJECT_NAME=Lumicoria
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# PostgreSQL Database Settings
POSTGRES_SERVER=your-postgres-server.com
POSTGRES_USER=your-postgres-user
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_DB=lumicoria
POSTGRES_PORT=5432
SQLALCHEMY_DATABASE_URI=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_SERVER}:${POSTGRES_PORT}/${POSTGRES_DB}

# MongoDB Settings
MONGODB_URI=mongodb://your-mongodb-server:27017
MONGODB_DB=lumicoria

# Redis Settings
REDIS_HOST=your-redis-server
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0

# Cassandra Settings
CASSANDRA_HOSTS=your-cassandra-server
CASSANDRA_KEYSPACE=lumicoria
CASSANDRA_USERNAME=your-cassandra-username
CASSANDRA_PASSWORD=your-cassandra-password

# Vector Store Settings (Weaviate)
VECTOR_STORE_URL=http://your-weaviate-server:8080
VECTOR_STORE_API_KEY=your-weaviate-api-key

# JWT Settings
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Firebase Settings (for authentication)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY=your-private-key
FIREBASE_CLIENT_EMAIL=your-client-email
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_X509_CERT_URL=your-cert-url

# LLM API Keys

PERPLEXITY_API_KEY=your-perplexity-api-key


# Integration Settings
GOOGLE_WORKSPACE_CLIENT_ID=your-google-client-id
GOOGLE_WORKSPACE_CLIENT_SECRET=your-google-client-secret
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
NOTION_CLIENT_ID=your-notion-client-id
NOTION_CLIENT_SECRET=your-notion-client-secret
SALESFORCE_CLIENT_ID=your-salesforce-client-id
SALESFORCE_CLIENT_SECRET=your-salesforce-client-secret

# Payment Settings (Stripe)
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Email Settings
SMTP_TLS=True
SMTP_PORT=587
SMTP_HOST=smtp.gmail.com
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
EMAILS_FROM_EMAIL=your-email@gmail.com
EMAILS_FROM_NAME=Lumicoria

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s


