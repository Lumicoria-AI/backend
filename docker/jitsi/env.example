# Lumicoria Meet — Self-hosted Jitsi env
# Copy to docker/jitsi/.env before first boot.
#
# Many values below need to be generated — see README "First-time setup"
# for the helper that fills in <random> placeholders.

# ── Image versioning (reproducible deploys) ───────────────────────
# Use a specific tag, not "stable". Bump and `docker compose pull` to upgrade.
# Tag list: https://github.com/jitsi/docker-jitsi-meet/releases
JITSI_IMAGE_VERSION=stable-10078

# ── Paths + ports ─────────────────────────────────────────────────
CONFIG=./.jitsi-meet-cfg
HTTP_PORT=8000
HTTPS_PORT=8443
TZ=UTC

# ── Domain + URLs ─────────────────────────────────────────────────
PUBLIC_URL=https://meet.lumicoria.ai
# Public IP of this VM — Coturn advertises it, JVB uses it for media.
DOCKER_HOST_ADDRESS=<your-vm-public-ip>

# ── XMPP backbone (internal — keep defaults) ──────────────────────
XMPP_DOMAIN=meet.jitsi
XMPP_AUTH_DOMAIN=auth.meet.jitsi
XMPP_BOSH_URL_BASE=http://prosody:5280
XMPP_GUEST_DOMAIN=guest.meet.jitsi
XMPP_MUC_DOMAIN=muc.meet.jitsi
XMPP_INTERNAL_MUC_DOMAIN=internal-muc.meet.jitsi
XMPP_RECORDER_DOMAIN=recorder.meet.jitsi
XMPP_SERVER=prosody

# ── Auth mode ─────────────────────────────────────────────────────
ENABLE_AUTH=1
ENABLE_GUESTS=1
ENABLE_LOBBY=1
ENABLE_PREJOIN_PAGE=0
AUTH_TYPE=jwt
JWT_ALLOW_EMPTY=0

# ── JWT (MUST match backend's JITSI_APP_ID + JITSI_APP_SECRET) ────
JWT_APP_ID=lumicoria
# Generate: openssl rand -hex 32
JWT_APP_SECRET=<paste-secret-here>
JWT_ACCEPTED_ISSUERS=lumicoria
JWT_ACCEPTED_AUDIENCES=jitsi
JWT_AUTH_TYPE=token

# ── Component shared secrets (generate via README helper) ─────────
# Each MUST be a unique random string.
JICOFO_AUTH_USER=focus
JICOFO_AUTH_PASSWORD=<random>
JICOFO_COMPONENT_SECRET=<random>
JVB_AUTH_USER=jvb
JVB_AUTH_PASSWORD=<random>
JVB_BREWERY_MUC=jvbbrewery
JVB_PORT=10000
JVB_TCP_PORT=4443
JVB_TCP_HARVESTER_DISABLED=false
# STUN servers — use Lumicoria's own coturn for primary, Jitsi's for fallback.
JVB_STUN_SERVERS=meet.lumicoria.ai:3478,meet-jit-si-turnrelay.jitsi.net:443

# Jibri (recording)
JIBRI_XMPP_USER=jibri
JIBRI_XMPP_PASSWORD=<random>
JIBRI_BREWERY_MUC=jibribrewery
JIBRI_RECORDER_USER=recorder
JIBRI_RECORDER_PASSWORD=<random>
JIBRI_RECORDING_DIR=/config/recordings
JIBRI_FINALIZE_RECORDING_SCRIPT_PATH=/config/finalize_recording.sh
JIBRI_STRIP_DOMAIN_JID=muc

# ── Coturn / TURN ─────────────────────────────────────────────────
# Required for participants behind symmetric NATs. The same secret
# is used by Jitsi's web service to mint per-user TURN credentials
# at room-join time (via the TURN REST API spec).
# Generate: openssl rand -hex 32
TURNCREDENTIALS_SECRET=<paste-secret-here>
TURN_HOST=meet.lumicoria.ai
TURNS_HOST=meet.lumicoria.ai
TURN_PORT=3478
TURNS_PORT=5349

# ── Lumicoria backend handoff (read by finalize_recording.sh) ─────
LUMICORIA_BACKEND_URL=https://api.lumicoria.ai
# Used to sign HMAC for /api/v1/huddles/jibri/webhook — must match
# backend's JITSI_APP_SECRET.
LUMICORIA_JIBRI_SECRET=<paste-secret-here>
LUMICORIA_MINIO_BUCKET=huddle-recordings
# MinIO credentials so Jibri can upload finalized recordings.
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=<minio-access-key>
MINIO_SECRET_KEY=<minio-secret-key>

# ── Let's Encrypt (optional — Cloudflare can terminate instead) ──
# When Cloudflare is in front, DISABLE_HTTPS=1 + Cloudflare → :HTTP_PORT.
# When direct, DISABLE_HTTPS=0 + the container handles TLS via Let's Encrypt.
DISABLE_HTTPS=1
LETSENCRYPT_DOMAIN=meet.lumicoria.ai
LETSENCRYPT_EMAIL=admin@lumicoria.ai
LETSENCRYPT_USE_STAGING=0
