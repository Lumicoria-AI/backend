# Lumicoria Meet — Jitsi env reference (READ-ONLY DOCUMENTATION)
#
# DO NOT copy this file to .env. The Jitsi stack reads from the PROJECT
# ROOT .env via `meet.sh` (which passes --env-file ../../../.env to
# docker compose). This file exists only as a reference of every
# variable the stack expects and what it does.
#
# To bootstrap the global .env, run:
#   scripts/jitsi_bootstrap.sh
# (or follow the README "First-time setup" section to write the values
# manually with `openssl rand -hex`).

# ── Image versioning (reproducible deploys) ───────────────────────
# Pin to a specific tag, not "stable". Bump and `meet.sh pull` to upgrade.
# Tag list: https://github.com/jitsi/docker-jitsi-meet/releases
JITSI_IMAGE_VERSION=stable-10078

# ── Paths + ports ─────────────────────────────────────────────────
CONFIG=./.jitsi-meet-cfg
HTTP_PORT=8800
HTTPS_PORT=8843
TZ=UTC

# ── Domain + URLs ─────────────────────────────────────────────────
PUBLIC_URL=https://meet.lumicoria.ai
# Public IP of this VM — Coturn advertises it, JVB uses it for media.
DOCKER_HOST_ADDRESS=<your-vm-public-ip>

# ── XMPP backbone (internal — keep defaults) ──────────────────────
XMPP_DOMAIN=meet.jitsi
XMPP_AUTH_DOMAIN=auth.meet.jitsi
XMPP_BOSH_URL_BASE=http://prosody:5280
XMPP_GUEST_DOMAIN=guest.meet.jitsi
XMPP_MUC_DOMAIN=muc.meet.jitsi
XMPP_INTERNAL_MUC_DOMAIN=internal-muc.meet.jitsi
XMPP_RECORDER_DOMAIN=recorder.meet.jitsi
XMPP_SERVER=prosody

# ── Auth mode ─────────────────────────────────────────────────────
ENABLE_AUTH=1
ENABLE_GUESTS=1
ENABLE_LOBBY=1
ENABLE_PREJOIN_PAGE=0
AUTH_TYPE=jwt
JWT_ALLOW_EMPTY=0
JWT_AUTH_TYPE=token

# ── JWT — backend signer side (services/jitsi_jwt.py reads these) ─
JITSI_DOMAIN=meet.lumicoria.ai
JITSI_APP_ID=lumicoria
JITSI_APP_SECRET=<generate: openssl rand -hex 32 — share with JWT_APP_SECRET>
JITSI_JWT_TTL_SECONDS=3600
JITSI_ENABLE_RECORDING_API=true
# Comma-separated CIDRs allowed to POST /huddles/jibri/webhook.
JITSI_JIBRI_ALLOWED_CIDR=
JITSI_LOGO_MAX_BYTES=1048576
JITSI_FAVICON_MAX_BYTES=204800

# ── JWT — Jitsi prosody side (MUST match JITSI_APP_* above) ───────
JWT_APP_ID=lumicoria
JWT_APP_SECRET=<same value as JITSI_APP_SECRET>
JWT_ACCEPTED_ISSUERS=lumicoria
JWT_ACCEPTED_AUDIENCES=jitsi

# ── Component shared secrets (each MUST be unique) ────────────────
JICOFO_AUTH_USER=focus
JICOFO_AUTH_PASSWORD=<generate: openssl rand -hex 24>
JICOFO_COMPONENT_SECRET=<generate: openssl rand -hex 24>
JVB_AUTH_USER=jvb
JVB_AUTH_PASSWORD=<generate: openssl rand -hex 24>
JVB_BREWERY_MUC=jvbbrewery
JVB_PORT=10000
JVB_TCP_PORT=4443
JVB_TCP_HARVESTER_DISABLED=false
JVB_STUN_SERVERS=meet.lumicoria.ai:3478,meet-jit-si-turnrelay.jitsi.net:443

# ── Jibri (recording) ─────────────────────────────────────────────
JIBRI_XMPP_USER=jibri
JIBRI_XMPP_PASSWORD=<generate: openssl rand -hex 24>
JIBRI_BREWERY_MUC=jibribrewery
JIBRI_RECORDER_USER=recorder
JIBRI_RECORDER_PASSWORD=<generate: openssl rand -hex 24>
JIBRI_RECORDING_DIR=/config/recordings
JIBRI_FINALIZE_RECORDING_SCRIPT_PATH=/config/finalize_recording.sh
JIBRI_STRIP_DOMAIN_JID=muc

# ── Coturn / TURN ─────────────────────────────────────────────────
TURNCREDENTIALS_SECRET=<generate: openssl rand -hex 32>
TURN_HOST=meet.lumicoria.ai
TURNS_HOST=meet.lumicoria.ai
TURN_PORT=3478
TURNS_PORT=5349

# ── Jibri → Lumicoria backend handoff ─────────────────────────────
LUMICORIA_BACKEND_URL=https://api.lumicoria.ai
# Same value as JWT_APP_SECRET — backend's HMAC verify expects it.
LUMICORIA_JIBRI_SECRET=<same value as JITSI_APP_SECRET>
LUMICORIA_MINIO_BUCKET=huddle-recordings
# MinIO endpoint reachable from inside the Jibri container.
# When MinIO runs on the same VM, use http://host.docker.internal:9000
# from Docker Desktop OR http://<vm-internal-ip>:9000 on Linux.
MINIO_ENDPOINT=http://host.docker.internal:9000
MINIO_ACCESS_KEY=<from backend .env>
MINIO_SECRET_KEY=<from backend .env>

# ── Let's Encrypt (off when Cloudflare terminates TLS) ───────────
DISABLE_HTTPS=1
LETSENCRYPT_DOMAIN=meet.lumicoria.ai
LETSENCRYPT_EMAIL=admin@lumicoria.ai
LETSENCRYPT_USE_STAGING=0
