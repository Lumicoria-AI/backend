      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "id": 8,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "lumicoria-prom" },
          "expr": "histogram_quantile(0.50, sum by (le, provider) (rate(lumicoria_ingest_embed_latency_seconds_bucket[5m])))",
          "legendFormat": "{{provider}} p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "lumicoria-prom" },
          "expr": "histogram_quantile(0.95, sum by (le, provider) (rate(lumicoria_ingest_embed_latency_seconds_bucket[5m])))",
          "legendFormat": "{{provider}} p95",
          "refId": "B"
        }
      ],
      "title": "Embed latency (p50 / p95, by provider)",
      "type": "timeseries"
