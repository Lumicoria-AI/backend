          "legendFormat": "OCR pages",
          "refId": "A"
        }
      ],
      "title": "OCR fallback (total pages)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "lumicoria-prom" },
      "description": "Chunks per second — split by source.  High throughput means a big doc was just ingested.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "insertNulls": false,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "lumicoria-prom" },
          "expr": "sum by (source) (rate(lumicoria_ingest_chunks_produced_total[5m]))",
          "legendFormat": "{{source}}",
          "refId": "A"
        }
      ],
      "title": "Chunks/sec by source (5m rate)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "lumicoria-prom" },
      "description": "p95 stage duration.  Watch for `embed` or `store` creeping up — that's where external services hurt you.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "lumicoria-prom" },
          "expr": "histogram_quantile(0.95, sum by (le, stage) (rate(lumicoria_ingest_duration_seconds_bucket[5m])))",
          "legendFormat": "{{stage}} p95",
          "refId": "A"
        }
      ],
      "title": "Stage duration (p95, by stage)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "lumicoria-prom" },
      "description": "Error rate per minute.  Spike = the worker is failing; check backend logs for the error code.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
