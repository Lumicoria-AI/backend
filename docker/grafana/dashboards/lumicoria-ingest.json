      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "lumicoria-prom" },
          "expr": "sum by (status) (rate(lumicoria_ingest_status_total{status!=\"ready\"}[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "title": "Error & cancel rate (5m)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "lumicoria-prom" },
      "description": "Embedding-provider latency per batch (p50 / p95).  Compare API providers vs local FastEmbed.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "never"
