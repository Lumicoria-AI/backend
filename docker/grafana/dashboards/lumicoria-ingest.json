      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "lumicoria-prom" },
          "expr": "sum(lumicoria_ingest_dedup_hits_total)",
          "legendFormat": "Dedup hits",
          "refId": "A"
        }
      ],
      "title": "Dedup hits",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "lumicoria-prom" },
      "description": "PDF pages that fell back to Tesseract because PyMuPDF found no text.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "purple", "value": null }
