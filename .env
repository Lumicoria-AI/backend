# API Settings
ENVIRONMENT=development
DEBUG=true
API_V1_STR=/api/v1
PROJECT_NAME=Lumicoria

# Replace with your actual frontend development and production origins, comma-separated
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# PostgreSQL Database Settings
# Replace with your actual PostgreSQL connection details
POSTGRES_SERVER=your_actual_postgres_server.com
POSTGRES_USER=your_actual_postgres_user
POSTGRES_PASSWORD=your_actual_postgres_password
POSTGRES_DB=lumicoria
POSTGRES_PORT=5432
# If you prefer to use a direct URI, uncomment the line below and provide your URI
# SQLALCHEMY_DATABASE_URI=postgresql+asyncpg://your_actual_user:your_actual_password@your_actual_host:5432/lumicoria

# MongoDB Settings
# Replace with your actual MongoDB connection URI and database name
MONGODB_URI=mongodb://your_actual_mongodb_server:27017
MONGODB_DB=lumicoria

# Redis Settings
# Replace with your actual Redis connection details
REDIS_HOST=your_actual_redis_server
REDIS_PORT=6379
# If Redis requires a password, uncomment the line below
# REDIS_PASSWORD=your_actual_redis_password
REDIS_DB=0

# Cassandra Settings
# Replace with your actual Cassandra hosts (comma-separated) and keyspace
CASSANDRA_HOSTS=your_actual_cassandra_server1,your_actual_cassandra_server2
CASSANDRA_PORT=9042
# If Cassandra requires credentials, uncomment the lines below
# CASSANDRA_USERNAME=your_actual_cassandra_username
# CASSANDRA_PASSWORD=your_actual_cassandra_password
CASSANDRA_KEYSPACE=lumicoria

# Vector Store Settings (Weaviate, Qdrant, or Chroma)
# Choose your vector store type and provide its URL
VECTOR_STORE_TYPE=weaviate  # Or qdrant, chroma
VECTOR_STORE_URL=http://your_actual_vector_store_server:8080
# If your vector store requires an API key, uncomment the line below
# VECTOR_STORE_API_KEY=your_actual_vector_store_api_key
VECTOR_STORE_COLLECTION=documents
VECTOR_STORE_DIMENSION=1536

# JWT Settings
# GENERATE A UNIQUE SECRET KEY FOR YOUR APPLICATION
SECRET_KEY=replace_this_with_a_very_long_and_random_string

# Firebase Settings (for authentication)
# Provide the path to your Firebase service account key file (if using Firebase auth)
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# LLM API Keys
# Uncomment and replace with your actual API keys if using these models
# OPENAI_API_KEY=your_actual_openai_api_key
# ANTHROPIC_API_KEY=your_actual_anthropic_api_key
# GOOGLE_API_KEY=your_actual_google_api_key
# PERPLEXITY_API_KEY=your_actual_perplexity_api_key
# DEEPSEEK_API_KEY=your_actual_deepseek_api_key

# Integration Settings
# Uncomment and replace with actual credentials for integrations you are using
# GOOGLE_WORKSPACE_CLIENT_ID=your_actual_google_client_id
# GOOGLE_WORKSPACE_CLIENT_SECRET=your_actual_google_client_secret
# SLACK_CLIENT_ID=your_actual_slack_client_id
# SLACK_CLIENT_SECRET=your_actual_slack_client_secret
# NOTION_CLIENT_ID=your_actual_notion_client_id
# NOTION_CLIENT_SECRET=your_actual_notion_client_secret
# SALESFORCE_CLIENT_ID=your_actual_salesforce_client_id
# SALESFORCE_CLIENT_SECRET=your_actual_salesforce_client_secret

# Payment Settings (Stripe)
# Uncomment and replace with actual Stripe keys if using payments
# STRIPE_SECRET_KEY=your_actual_stripe_secret_key
# STRIPE_WEBHOOK_SECRET=your_actual_stripe_webhook_secret

# Email Settings
# Uncomment and configure if using email features
# SMTP_TLS=True
# SMTP_PORT=587
# SMTP_HOST=smtp.gmail.com # Or your SMTP server
# SMTP_USER=your_actual_email@gmail.com
# SMTP_PASSWORD=your_actual_app_specific_password
# EMAILS_FROM_EMAIL=your_actual_email@gmail.com
# EMAILS_FROM_NAME=Lumicoria

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Sentry Configuration
# SENTRY_DSN=your_actual_sentry_dsn
