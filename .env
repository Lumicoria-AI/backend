# ===========================================================================
# Lumicoria AI — Backend Environment Variables
# ===========================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ===========================================================================

# ── REQUIRED ──────────────────────────────────────────────────────────────
# The app will refuse to start without SECRET_KEY.
# At least ONE LLM API key is required (matching your DEFAULT_LLM_PROVIDER).

# JWT signing key — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ── LLM PROVIDER SELECTION ───────────────────────────────────────────────
# Which LLM provider to use by default. Options: perplexity, gemini, openai, anthropic, mistral
DEFAULT_LLM_PROVIDER=gemini
# Optional: fallback provider if the primary is unavailable
# LLM_FALLBACK_PROVIDER=gemini
# Optional: separate provider for embeddings (defaults to DEFAULT_LLM_PROVIDER)
# DEFAULT_EMBEDDING_PROVIDER=perplexity

# Perplexity Sonar API key (required if DEFAULT_LLM_PROVIDER=perplexity)
# Get from https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# Google Gemini API key (required if DEFAULT_LLM_PROVIDER=gemini)

GEMINI_API_KEY=AIzaSyAIRJjdr6YhFtDXO9bjp-sAUwvxz0P4xzM
# Models: gemini-2.5-pro-preview-06-05, gemini-2.5-flash-preview-05-20,
#         gemini-2.0-pro, gemini-2.0-flash, gemini-2.0-flash-lite,
#         gemini-1.5-pro, gemini-1.5-flash
GEMINI_MODEL=gemini-2.0-flash
# HTTP timeout in seconds
GEMINI_TIMEOUT=60

# ── ENVIRONMENT ───────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ── GOOGLE OAUTH ──────────────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=

# ── STRIPE BILLING ────────────────────────────────────────────────────────
# Get keys from https://dashboard.stripe.com/apikeys
# Use sk_test_ / pk_test_ for development, sk_live_ / pk_live_ for production
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Webhook signing secret — get from https://dashboard.stripe.com/webhooks
# For local dev: stripe listen --forward-to localhost:8000/api/v1/billing/webhook
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs — create in https://dashboard.stripe.com/products
# These map to your subscription plans. NEVER hardcode.
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_ENTERPRISE=

# Redirect URLs after Stripe Checkout
STRIPE_SUCCESS_URL=http://localhost:3000/dashboard?billing=success
STRIPE_CANCEL_URL=http://localhost:3000/pricing?billing=canceled

# ── FIREBASE ──────────────────────────────────────────────────────────────
# Path to Firebase Admin SDK service-account JSON file
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# ── MONGODB ───────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=lumicoria

# ── POSTGRESQL / SQLALCHEMY (optional) ───────────────────────────────────
POSTGRES_ENABLED=false
POSTGRES_DUAL_WRITE=false
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=lumicoria
# Optional override:
# SQLALCHEMY_DATABASE_URI=postgresql://postgres:password@localhost:5432/lumicoria

# ── CASSANDRA (optional) ────────────────────────────────────────────────
CASSANDRA_ENABLED=false
CASSANDRA_DUAL_WRITE=false
CASSANDRA_HOSTS=["localhost"]
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=lumicoria
CASSANDRA_REPLICATION_FACTOR=1
CASSANDRA_USERNAME=
CASSANDRA_PASSWORD=

# ── REDIS ─────────────────────────────────────────────────────────────────
# Used for rate limiting and caching
# (nested settings under "db" prefix also work — see config.py)

# ── VECTOR STORE ──────────────────────────────────────────────────────────
# VECTOR_STORE_TYPE=weaviate|qdrant|chroma
VECTOR_STORE_TYPE=weaviate
VECTOR_STORE_URL=http://localhost:8081
VECTOR_STORE_API_KEY=
VECTOR_STORE_COLLECTION=documents
VECTOR_STORE_DIMENSION=1536
VECTOR_STORE_ENABLED=true

# ── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list or JSON array of allowed origins
BACKEND_CORS_ORIGINS=["http://localhost:8080","http://localhost:3000","http://127.0.0.1:8080","http://127.0.0.1:3000"]

# ── EMAIL PROVIDERS (production email delivery) ──────────────────────────
# SendGrid (primary) - Get API key from https://sendgrid.com
SENDGRID_API_KEY=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

# Resend (fallback) - Get API key from https://resend.com  
RESEND_API_KEY=re_AUJoWFHo_Bzzkexz4sS6MRa9semuH7p5e

# Email configuration
EMAIL_FROM_ADDRESS=noreply@lumicoria.ai
EMAIL_FROM_NAME=Lumicoria.ai
EMAIL_SANDBOX_MODE=false

# ── INTEGRATION ENCRYPTION ───────────────────────────────────────────────
# Fernet key for encrypting third-party integration credentials.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: If you lose this key, all encrypted integration creds become unreadable.
INTEGRATION_ENCRYPTION_KEY=
# ── OPENAI (optional — required if DEFAULT_LLM_PROVIDER=openai) ──────────
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Models: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo, o1, o1-mini, o3-mini
OPENAI_MODEL=gpt-4o-mini
# HTTP timeout in seconds
OPENAI_TIMEOUT=30

# ── ANTHROPIC (optional — required if DEFAULT_LLM_PROVIDER=anthropic) ────
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Models: claude-3-5-sonnet-latest, claude-3-5-haiku-latest, claude-3-opus-latest, claude-sonnet-4-20250514
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# HTTP timeout in seconds
ANTHROPIC_TIMEOUT=60

# ── MISTRAL (optional — required if DEFAULT_LLM_PROVIDER=mistral) ────────
# Get from https://console.mistral.ai/api-keys
MISTRAL_API_KEY=
# Models: mistral-large-latest, mistral-small-latest, open-mistral-nemo,
#         codestral-latest, pixtral-large-latest, mistral-saba-latest
MISTRAL_MODEL=mistral-large-latest
# HTTP timeout in seconds
MISTRAL_TIMEOUT=30

# ── SENTRY (optional — error monitoring) ──────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── CLOUD PROVIDERS (optional) ───────────────────────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── THIRD-PARTY INTEGRATIONS (optional) ──────────────────────────────────
NOTION_API_KEY=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=

